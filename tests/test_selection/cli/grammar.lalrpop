grammar;

use storage_manager::backend::executor::selection::{
    Predicate, Expr, Constant, ColumnReference, ComparisonOp
};

pub PredicateParser: Predicate = {
    <p:OrExpr> => p
};

OrExpr: Predicate = {
    <l:OrExpr> "OR" <r:AndExpr> => Predicate::Or(Box::new(l), Box::new(r)),
    <a:AndExpr> => a
};

AndExpr: Predicate = {
    <l:AndExpr> "AND" <r:NotExpr> => Predicate::And(Box::new(l), Box::new(r)),
    <n:NotExpr> => n
};

NotExpr: Predicate = {
    "NOT" <p:PrimaryPred> => Predicate::Not(Box::new(p)),
    <p:PrimaryPred> => p
};

PrimaryPred: Predicate = {
    <l:Expr> <op:CompOp> <r:Expr> => Predicate::Compare(Box::new(l), op, Box::new(r)),
    <e:Expr> "IS" "NULL" => Predicate::IsNull(Box::new(e)),
    <e:Expr> "IS" "NOT" "NULL" => Predicate::IsNotNull(Box::new(e)),
    <e:Expr> "BETWEEN" <low:Expr> "AND" <high:Expr> => Predicate::Between(Box::new(e), Box::new(low), Box::new(high)),
    <e:Expr> "NOT" "BETWEEN" <low:Expr> "AND" <high:Expr> => Predicate::Not(Box::new(Predicate::Between(Box::new(e), Box::new(low), Box::new(high)))),
    <e:Expr> "IN" "(" <list:CommaExprList> ")" => Predicate::In(Box::new(e), list),
    <e:Expr> "NOT" "IN" "(" <list:CommaExprList> ")" => Predicate::Not(Box::new(Predicate::In(Box::new(e), list))),
    <e:Expr> "LIKE" <pattern:StringLit> => Predicate::Like(Box::new(e), pattern, None),
    "(" <p:PredicateParser> ")" => p
};

CompOp: ComparisonOp = {
    "="  => ComparisonOp::Equals,
    "!=" => ComparisonOp::NotEquals,
    "<"  => ComparisonOp::LessThan,
    ">"  => ComparisonOp::GreaterThan,
    "<=" => ComparisonOp::LessOrEqual,
    ">=" => ComparisonOp::GreaterOrEqual,
};

Expr: Expr = {
    <l:Expr> "+" <r:Term> => Expr::Add(Box::new(l), Box::new(r)),
    <l:Expr> "-" <r:Term> => Expr::Sub(Box::new(l), Box::new(r)),
    <t:Term> => t
};

Term: Expr = {
    <l:Term> "*" <r:Factor> => Expr::Mul(Box::new(l), Box::new(r)),
    <l:Term> "/" <r:Factor> => Expr::Div(Box::new(l), Box::new(r)),
    <f:Factor> => f
};

Factor: Expr = {
    <n:Number> => Expr::Constant(n),

    
    <s:StringLit> => {
        if s.len() == 10 &&
           s.as_bytes()[4] == b'-' &&
           s.as_bytes()[7] == b'-' {
            Expr::Constant(Constant::Date(s))
        } else {
            Expr::Constant(Constant::Text(s))
        }
    },

    "NULL" => Expr::Constant(Constant::Null),

    <id:Ident> => Expr::Column(ColumnReference::new(id)),

    "(" <e:Expr> ")" => e
};

Number: Constant = {
    <f:r"[0-9]+\.[0-9]+"> => Constant::Float(f.parse().unwrap()),
    <i:r"[0-9]+"> => Constant::Int(i.parse().unwrap()),
};

StringLit: String = {
    <s:r#""[^"]*""#> => s[1..s.len()-1].to_string()
};

Ident: String = {
    <id:r"[a-zA-Z_][a-zA-Z0-9_]*"> => id.to_string()
};

CommaExprList: Vec<Expr> = {
    <e:Expr> => vec![e],
    <list:CommaExprList> "," <e:Expr> => {
        let mut list = list;
        list.push(e);
        list
    }
};